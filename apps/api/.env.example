# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nkc_crm"

# JWT
JWT_SECRET="change-me-to-a-random-64-char-string"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# FlexPay (Mobile Money RDC) — Étape 07
# Leave TOKEN/MERCHANT empty to run in MOCK mode (payments settle instantly,
# no real provider call) — useful for sandbox dev and CI.
FLEXPAY_TOKEN=
FLEXPAY_MERCHANT_CODE=
FLEXPAY_BASE_URL=https://backend.flexpay.cd/api/rest/v1/paymentService
FLEXPAY_CURRENCY=USD
# Public URL of THIS API — FlexPay posts the payment confirmation to
# ${API_PUBLIC_URL}/webhooks/flexpay
API_PUBLIC_URL=http://localhost:3001
